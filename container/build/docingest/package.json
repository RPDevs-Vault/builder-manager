  "scripts": {
    "dev-start": "PORT=8000 react-scripts start",
    "build": "react-scripts build",
    "build:deploy": "react-scripts build && npm run deploy",
    "deploy": "sudo cp -r build/* /var/www/html/ && sudo chown -R www-data:www-data /var/www/html/ && sudo systemctl reload nginx",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "server": "tsx server/server.ts",
    "dev": "concurrently \"npm run server\" \"npm run dev-start\"",
    "dev:local": "PORT=8011 REACT_APP_API_URL=http://localhost:8011/api concurrently \"npm run server\" \"npm run dev-start\"",
    "migrate:versions": "npx tsx server/scripts/migrate-to-versioning.ts"
  },
