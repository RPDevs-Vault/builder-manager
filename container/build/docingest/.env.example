# DocIngest environment configuration.
# Copy this file to `.env` in the repo root and fill in your values.
# The backend (Bun) auto-loads `.env` from the repo root at startup.

# --- Crawl provider ---------------------------------------------------------
# Firecrawl is the default, so CRAWL_PROVIDER is optional when using Firecrawl.
CRAWL_PROVIDER=firecrawl

# Hosted Firecrawl (https://firecrawl.dev): set your API key.
FIRECRAWL_API_KEY=fc-your-api-key-here
FIRECRAWL_API_URL=https://api.firecrawl.dev/v1

# Self-hosted Firecrawl instead: comment out the two lines above and use:
# FIRECRAWL_API_URL=http://localhost:3002/v1

# Cloudflare Browser Rendering alternative (set CRAWL_PROVIDER=cloudflare):
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# --- App --------------------------------------------------------------------
REACT_APP_API_URL=http://localhost:8001/api

# --- Redis ------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6380
